# ── Gemini (default) ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── LLM Provider switch ───────────────────────────────────────────────────────
# Set to "ollama" to run fully offline on your local GPU (RTX 5070 recommended)
# Leave as "gemini" to use the Google Gemini API
LLM_PROVIDER=gemini

# ── Ollama settings (only used when LLM_PROVIDER=ollama) ─────────────────────
# First install Ollama: https://ollama.com
# Then pull a model:    ollama pull llama3.1:8b
# Recommended for RTX 5070 (12 GB VRAM):
#   llama3.1:8b   — best balance of speed and quality
#   qwen2.5:7b    — very strong on structured / financial text
#   mistral:7b    — good reasoning
#   gemma3:12b    — highest quality that fits in 12 GB
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Relevance gate ────────────────────────────────────────────────────────────
# Cross-encoder scores below this skip the LLM entirely.
# -12 is a safe default; lower = more permissive, higher = stricter
# -20 = effectively disabled (let the LLM decide via the consultation prompt)
# Only enable a hard gate (e.g. -5) if your corpus is large enough that truly
# irrelevant queries score significantly below relevant ones on ms-marco-MiniLM
RELEVANCE_THRESHOLD=-20.0

# ── Diversity-aware selection ─────────────────────────────────────────────────
# After re-ranking, re-select the final top-K for relevance AND source diversity
# (Maximal Marginal Relevance + a per-source quota) so answers draw on multiple
# documents instead of near-duplicate chunks from one.
#   ENABLE_DIVERSITY=false → legacy behaviour (plain rerank top-K)
#   DIVERSITY_POOL         → how many chunks to rerank before selecting
#   MMR_LAMBDA             → 1.0 = relevance only (off), 0.0 = diversity only
#   MAX_PER_SOURCE         → hard cap on chunks from a single source file
ENABLE_DIVERSITY=true
DIVERSITY_POOL=15
MMR_LAMBDA=0.7
MAX_PER_SOURCE=2
